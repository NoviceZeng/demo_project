pipeline {
    agent {
       node {
           label 'agent1'
       }
    }

	environment {
        // Harbor registry address
        Harbor_Repo = "harbor.test.com"      
	    // Harbor registry password should be injected as an environment variable in Jenkins
    Harbor_Password = "${HARBOR_PASSWORD}"
	    // Base Git path used to clone the demo-app-code monorepo
        Monorepo_Base_Repo = "ssh://git@git.test.com/demo-app-cloud/"
        // SonarQube configuration
        SONARQUBE_HOST_URL = "http://sonarqube.test.com"
        SONARQUBE_LOGIN = "${SONARQUBE_TOKEN}"
	}	

    parameters {
        choice choices: ['api-gateway:8080', 'user-service:9002', 'product-service:9003', 'order-service:9006', 'payment-service:9007'], description: 'Select the demo-app-code microservice module to build and deploy', name: 'Microsvc'
        string defaultValue: 'dev', description: 'Enter the demo-app-code Git branch to build from', name: 'GitBranch', trim: true
        choice choices: ['dev', 'test', 'perf'], description: 'Select the deployment environment', name: 'TargetEnvironment'
        string defaultValue: '1', description: 'Enter the Kubernetes replica count', name: 'ReplicaCount', trim: true
        booleanParam defaultValue: false, description: 'Build and push the image only. Skip Kubernetes deployment.', name: 'BuildOnly'
    }
	

    stages {      
        stage('Git Clone') {
            steps {
                script {
                    sh 'sh scripts/git_util.sh ${Microsvc} ${GitBranch} ${Monorepo_Base_Repo}'
                    git_commit = sh (script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    currentBuild.displayName = "${git_commit}"
                    currentBuild.description = "${Microsvc} - ${TargetEnvironment} - ${GitBranch}"
                }
            }
        }
        
        stage('Build java code') {
            steps {
                script {
                    sh 'sh scripts/java_build.sh ${Microsvc}'
                }
            }
        }

        stage('SonarQube scan') {
            steps {
                script {
                    def scanResult = sh(
                        script: 'sh scripts/sonarqube_scan.sh ${Microsvc} ${SONARQUBE_HOST_URL} ${SONARQUBE_LOGIN}',
                        returnStatus: true
                    )
                    if (scanResult != 0) {
                        echo 'SonarQube scan FAILED'
                        currentBuild.result = 'FAILURE'
                        error('SonarQube scan failed. Stopping pipeline.')
                    } else {
                        echo 'SonarQube scan PASSED'
                    }
                }
            }
        }
     
        stage('Making docker image') {
            when {
                expression { currentBuild.result == null || currentBuild.result == 'SUCCESS' }
            }
            steps {
                script {
                    sh 'sh scripts/docker_image.sh ${Microsvc} ${Harbor_Repo} ${BUILD_NUMBER} ${GitBranch}'
                }
            }
        }

        stage('Deploy svc to k8s cluster') {
            when {
                expression { !params.BuildOnly && (currentBuild.result == null || currentBuild.result == 'SUCCESS') }
            }
            steps {
                script {
                    sh 'sh scripts/helm_deploy.sh ${Microsvc} ${TargetEnvironment} ${BUILD_NUMBER} ${ReplicaCount}' 
                }
            }
        }
    }
    post {
        success {
            dingtalk (
                robot: 'Jenkins-Dingtalk',
                type: 'MARKDOWN',
                title: "success: ${JOB_NAME}",
                text: [
                    "### [${env.JOB_NAME}](${env.JOB_URL}) ",
                    '---',
                    "- Build: [${currentBuild.displayName}](${env.BUILD_URL})",
                    '- Status: **<font>SUCCESS</font>**',
                    "- Duration: ${currentBuild.durationString}".split("and counting")[0],
                    "- ${currentBuild.buildCauses.shortDescription}",
                ]
            )
        }
    }
}
